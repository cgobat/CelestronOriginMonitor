####### Compile

build/obj/main.o: main.cpp TelescopeGUI.hpp \
		TelescopeDataProcessor.hpp \
		TelescopeData.hpp \
		CommandInterface.hpp
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/obj/main.o main.cpp

build/obj/TelescopeDataProcessor.o: TelescopeDataProcessor.cpp TelescopeDataProcessor.hpp \
		TelescopeData.hpp
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/obj/TelescopeDataProcessor.o TelescopeDataProcessor.cpp

build/obj/TelescopeGUI.o: TelescopeGUI.cpp TelescopeGUI.hpp \
		TelescopeDataProcessor.hpp \
		TelescopeData.hpp \
		CommandInterface.hpp \
		OriginBackend.hpp \
		MessierCatalog.hpp
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/obj/TelescopeGUI.o TelescopeGUI.cpp

build/obj/CoordinateUtils.o: CoordinateUtils.cpp CoordinateUtils.hpp
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/obj/CoordinateUtils.o CoordinateUtils.cpp

build/obj/TelescopeDataProcessor.o: TelescopeDataProcessor.cpp TelescopeDataProcessor.hpp \
		TelescopeData.hpp
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/obj/TelescopeDataProcessor.o TelescopeDataProcessor.cpp

build/obj/TelescopeGUI.o: TelescopeGUI.cpp TelescopeGUI.hpp \
		TelescopeDataProcessor.hpp \
		TelescopeData.hpp \
		CommandInterface.hpp \
		OriginBackend.hpp \
		MessierCatalog.hpp
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/obj/TelescopeGUI.o TelescopeGUI.cpp

build/obj/OriginBackend.o: OriginBackend.cpp OriginBackend.hpp \
		TelescopeDataProcessor.hpp \
		TelescopeData.hpp
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/obj/OriginBackend.o OriginBackend.cpp

build/obj/moc_TelescopeDataProcessor.o: build/moc/moc_TelescopeDataProcessor.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/obj/moc_TelescopeDataProcessor.o build/moc/moc_TelescopeDataProcessor.cpp

build/obj/moc_TelescopeGUI.o: build/moc/moc_TelescopeGUI.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/obj/moc_TelescopeGUI.o build/moc/moc_TelescopeGUI.cpp

build/obj/moc_OriginBackend.o: build/moc/moc_OriginBackend.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/obj/moc_OriginBackend.o build/moc/moc_OriginBackend.cpp

####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/CelestronOriginMonitor/bin || mkdir -p $(INSTALL_ROOT)/opt/CelestronOriginMonitor/bin
	$(QINSTALL_PROGRAM) build/$(QMAKE_TARGET) $(INSTALL_ROOT)/opt/CelestronOriginMonitor/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/opt/CelestronOriginMonitor/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/CelestronOriginMonitor/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/CelestronOriginMonitor/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

.SUFFIXES:

